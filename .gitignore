# ============================================================================
# Lucy — Git Ignore Rules
# ============================================================================
# See https://help.github.com/articles/ignoring-files/ for more info.
# ============================================================================

# ---------------------------------------------------------------------------
# Secrets & Environment Files
# ---------------------------------------------------------------------------
# Never commit real environment files with secrets.
# .env.example IS committed as template/documentation.
.env
.env.*
!.env.example

# OAuth credentials and tokens
*token.json*
*credentials.json*
backend/credentials/

# ---------------------------------------------------------------------------
# IDEs and Editors
# ---------------------------------------------------------------------------
.idea/
.vscode/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
venv/
.venv/
.pytest_cache/

# ---------------------------------------------------------------------------
# Build & Production Artifacts
# ---------------------------------------------------------------------------
/build
dist/
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
/coverage

# ---------------------------------------------------------------------------
# Caches
# ---------------------------------------------------------------------------
.cache/
frontend/node_modules/.cache/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
backend.log
frontend.log
mongo.log
dump.rdb

# ---------------------------------------------------------------------------
# System Files
# ---------------------------------------------------------------------------
.DS_Store
*.pem

# ---------------------------------------------------------------------------
# Archives and Large Assets
# ---------------------------------------------------------------------------
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# ---------------------------------------------------------------------------
# External Tools (Legacy)
# ---------------------------------------------------------------------------
# Emergent platform artifacts (no longer used)
.emergent/
emergent/
emergent.yml
*.emergent

# Chainlit (no longer used)
chainlit.md
.chainlit
.ipynb_checkpoints/

# Vercel (not used currently)
.vercel

# ---------------------------------------------------------------------------
# Project-Specific
# ---------------------------------------------------------------------------
# Data storage (local only)
agenthub/agents/youtube/db
test_reports/

# Mobile SDKs (not tracked)
android-sdk/

# Temporary / user-specific
.ac
su/

# Local backup files (.bak) — not committed
*.bak
*.bak-*
