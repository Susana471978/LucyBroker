# ============================================================================
# Lucy Backend — Environment Variables Template
# ============================================================================
# Copy this file to .env.development (local) or .env.production (VPS)
# and fill in the actual values. Never commit .env.development or
# .env.production to version control.
# ============================================================================

# --- Database ---
# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Database name: email_control_system (prod) or email_control_system_dev (local)
DB_NAME=email_control_system_dev

# --- Authentication ---
# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET=

# --- Voice (TTS / Speech) ---
# OpenAI API key for GPT and Whisper
OPENAI_API_KEY=sk-proj-...
# ElevenLabs (fallback TTS provider, not currently active)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Google OAuth (Gmail + Calendar) ---
# Redirect URIs must match what's registered in Google Cloud Console
GMAIL_REDIRECT_URI=https://your-domain.com/api/gmail/oauth/callback
CALENDAR_REDIRECT_URI=https://your-domain.com/api/calendar/oauth/callback
# Relax OAuth scope validation (set to "1" to allow scope drift during refresh)
OAUTHLIB_RELAX_TOKEN_SCOPE=1

# --- Frontend ---
# Base URL of the frontend app (for CORS and redirects)
FRONTEND_URL=https://lucy.syntexia-solutions.es

# --- Stripe Billing ---
# Stripe API keys (use test keys in development, live keys in production)
STRIPE_SECRET_KEY=sk_test_... or sk_live_...
# Webhook endpoint signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for subscription plans
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
